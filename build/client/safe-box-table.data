[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_42":-7,"_43":20,"_44":45,"_174":175},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_26":27,"_40":41},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":8},72,"Safe Box Earnings","safe-box-table","navbarTitle","gameId","sectionId",16,"sort","blocks",[28],{"_7":29,"_30":18,"_31":32,"_36":37,"_33":-5,"_38":39},303,"pageId","content",{"_33":34,"_31":35},"type","richText","<div class=\"text-width\">\n<h2 class=\"section-header\">Actual Safe Box earnings</h2>\n<p>In&nbsp;<a href=\"https://luckydefenseguides.com/pages/sb-mg.html\">What's mg/sb?</a>&nbsp;we talked about what mg/sb are. If you earned no gold from enemies or challenges and only earned gold from Safe Box artifact, assuming you started with 100 gold, this is how much all the safebox levels would gain if just let that sit over 80 waves.</p>\n<p>These are all pretty good numbers as is, but considering this is only assuming you have no other income, you can imagine how much more you'll actually get than this. With level 5 Safe Box and good gold management, you can get up to 400k gold nearly every game. With lower levels, 100k is still easily reachable, sometimes even more. To see why Safe Box and Money Gun are the most powerful artifacts in the game&nbsp;<a href=\"https://luckydefenseguides.com/pages/sb-mg.html\">click here.</a></p>\n<p>Good luck!</p>\n</div>\n<table>\n<thead>\n<tr>\n<th>Safebox Level</th>\n<th>Coins After 80 Waves</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Level 1</td>\n<td>4,956 Coins</td>\n</tr>\n<tr>\n<td>Level 2</td>\n<td>7,247 Coins</td>\n</tr>\n<tr>\n<td>Level 3</td>\n<td>10,579 Coins</td>\n</tr>\n<tr>\n<td>Level 4</td>\n<td>15,415 Coins</td>\n</tr>\n<tr>\n<td>Level 5</td>\n<td>22,423 Coins</td>\n</tr>\n<tr>\n<td>Level 6</td>\n<td>32,559 Coins</td>\n</tr>\n<tr>\n<td>Level 7</td>\n<td>47,195 Coins</td>\n</tr>\n<tr>\n<td>Level 8</td>\n<td>68,293 Coins</td>\n</tr>\n<tr>\n<td>Level 9</td>\n<td>98,655 Coins</td>\n</tr>\n<tr>\n<td>Level 10</td>\n<td>142,275 Coins</td>\n</tr>\n<tr>\n<td>Level 11</td>\n<td>204,840 Coins</td>\n</tr>\n</tbody>\n</table>\n<p>&nbsp;</p>","order",32,"files",[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",46,47,55,56,71,87,8,94,109,110,129,130,136,137,24,153],11,{"_7":46,"_9":48,"_36":49,"_22":8,"_50":51},"Main",0,"pages",[52],{"_7":53,"_9":54,"_11":12,"_21":-5,"_22":8,"_23":46,"_25":-5},56,"LD Homepage",12,{"_7":55,"_9":57,"_36":8,"_22":8,"_50":58},"Fundamentals",[59,63,67,72,77,82],{"_7":60,"_9":61,"_11":62,"_21":-5,"_22":8,"_23":55,"_25":49},59,"What's sb/mg?","sb-mg",{"_7":64,"_9":65,"_11":66,"_21":-5,"_22":8,"_23":55,"_25":8},60,"Mythic Categories","mythic-categories",{"_7":68,"_9":69,"_11":70,"_21":-5,"_22":8,"_23":55,"_25":71},57,"How to use stuns","stun-guide",2,{"_7":73,"_9":74,"_11":75,"_21":-5,"_22":8,"_23":55,"_25":76},58,"Defense Reduction Guide","defense-reduction",3,{"_7":78,"_9":79,"_11":80,"_21":-5,"_22":8,"_23":55,"_25":81},61,"MP Regen Guide","mp-regen",4,{"_7":83,"_9":84,"_11":85,"_21":-5,"_22":8,"_23":55,"_25":86},62,"Attack Speed Increase","attack-speed",5,{"_7":71,"_9":88,"_36":71,"_22":8,"_50":89},"General",[90],{"_7":91,"_9":92,"_11":93,"_21":-5,"_22":8,"_23":71,"_25":-5},81,"Guardian Upgrade Costs","guardian-upgrade-costs",{"_7":8,"_9":95,"_36":76,"_22":8,"_50":96},"Hard Mode",[97,101,105],{"_7":98,"_9":99,"_11":100,"_21":-5,"_22":8,"_23":8,"_25":49},112,"Hard Gameplay Guide","hard-gameplay",{"_7":102,"_9":103,"_11":104,"_21":-5,"_22":8,"_23":8,"_25":8},80,"Mythic Unlock Order","unlock-order-hard",{"_7":106,"_9":107,"_11":108,"_21":-5,"_22":8,"_23":8,"_25":71},83,"Lance-Kitty Strategy","lance-kitty",13,{"_7":109,"_9":111,"_36":81,"_22":8,"_50":112},"Hell Mode",[113,117,121,125],{"_7":114,"_9":115,"_11":116,"_21":-5,"_22":8,"_23":109,"_25":49},66,"Hell Mode Guide","hell-mode",{"_7":118,"_9":119,"_11":120,"_21":-5,"_22":8,"_23":109,"_25":8},65,"Hel