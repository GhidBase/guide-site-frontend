[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_43":-7,"_44":20,"_45":46,"_174":175},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_27":28,"_41":42},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":26},70,"Treasure Upgrade Costs","treasure-upgrade-costs","navbarTitle","gameId","sectionId",15,"sort",2,"blocks",[29],{"_7":30,"_31":18,"_32":33,"_37":38,"_34":-5,"_39":40},301,"pageId","content",{"_34":35,"_32":36},"type","richText","<div class=\"text-width\">\n<div class=\"text-width\">\n<p><strong>Note:</strong>&nbsp;When treasure level up fails, you gain&nbsp;<strong>+% increment</strong>&nbsp;to the base success rate, up to 10 times total.</p>\n</div>\n<table>\n<thead>\n<tr>\n<th>Level</th>\n<th>Success Rate</th>\n<th>Cost</th>\n<th>Increment</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>1 &rarr; 2</td>\n<td>90%</td>\n<td>5,000 coins 🪙</td>\n<td>+9%</td>\n</tr>\n<tr>\n<td>2 &rarr; 3</td>\n<td>80%</td>\n<td>10,000 coins 🪙</td>\n<td>+8%</td>\n</tr>\n<tr>\n<td>3 &rarr; 4</td>\n<td>70%</td>\n<td>15,000 coins 🪙</td>\n<td>+7%</td>\n</tr>\n<tr>\n<td>4 &rarr; 5</td>\n<td>60%</td>\n<td>20,000 coins 🪙</td>\n<td>+6%</td>\n</tr>\n<tr>\n<td>5 &rarr; 6</td>\n<td>50%</td>\n<td>25,000 coins 🪙</td>\n<td>+5%</td>\n</tr>\n<tr>\n<td>6 &rarr; 7</td>\n<td>40%</td>\n<td>30,000 coins 🪙 + 1 Red Ticket 🎟️</td>\n<td>+4%</td>\n</tr>\n<tr>\n<td>7 &rarr; 8</td>\n<td>30%</td>\n<td>35,000 coins 🪙 + 1 Red Ticket 🎟️</td>\n<td>+3%</td>\n</tr>\n<tr>\n<td>8 &rarr; 9</td>\n<td>15%</td>\n<td>40,000 coins 🪙 + 1 Red Ticket 🎟️</td>\n<td>+1.5%</td>\n</tr>\n<tr>\n<td>9 &rarr; 10</td>\n<td>5%</td>\n<td>45,000 coins 🪙 + 1 Red Ticket 🎟️</td>\n<td>+0.5%</td>\n</tr>\n<tr>\n<td>10 &rarr; 11</td>\n<td>1%</td>\n<td>50,000 coins 🪙 + 1 Red Ticket 🎟️</td>\n<td>+0.1%</td>\n</tr>\n</tbody>\n</table>\n<div class=\"text-width\">\n<p>Credit to Yosh and Jubilent for gathering data about the treasure system, who gathered the information and posted it all on the discord before I was able to add it here.</p>\n</div>\n</div>","order",32,"files",[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",47,48,56,57,26,87,8,94,109,110,129,130,24,136,149,150],11,{"_7":47,"_9":49,"_37":50,"_22":8,"_51":52},"Main",0,"pages",[53],{"_7":54,"_9":55,"_11":12,"_21":-5,"_22":8,"_23":47,"_25":-5},56,"LD Homepage",12,{"_7":56,"_9":58,"_37":8,"_22":8,"_51":59},"Fundamentals",[60,64,68,72,77,82],{"_7":61,"_9":62,"_11":63,"_21":-5,"_22":8,"_23":56,"_25":50},59,"What's sb/mg?","sb-mg",{"_7":65,"_9":66,"_11":67,"_21":-5,"_22":8,"_23":56,"_25":8},60,"Mythic Categories","mythic-categories",{"_7":69,"_9":70,"_11":71,"_21":-5,"_22":8,"_23":56,"_25":26},57,"How to use stuns","stun-guide",{"_7":73,"_9":74,"_11":75,"_21":-5,"_22":8,"_23":56,"_25":76},58,"Defense Reduction Guide","defense-reduction",3,{"_7":78,"_9":79,"_11":80,"_21":-5,"_22":8,"_23":56,"_25":81},61,"MP Regen Guide","mp-regen",4,{"_7":83,"_9":84,"_11":85,"_21":-5,"_22":8,"_23":56,"_25":86},62,"Attack Speed Increase","attack-speed",5,{"_7":26,"_9":88,"_37":26,"_22":8,"_51":89},"General",[90],{"_7":91,"_9":92,"_11":93,"_21":-5,"_22":8,"_23":26,"_25":-5},81,"Guardian Upgrade Costs","guardian-upgrade-costs",{"_7":8,"_9":95,"_37":76,"_22":8,"_51":96},"Hard Mode",[97,101,105],{"_7":98,"_9":99,"_11":100,"_21":-5,"_22":8,"_23":8,"_25":50},112,"Hard Gameplay Guide","hard-gameplay",{"_7":102,"_9":103,"_11":104,"_21":-5,"_22":8,"_23":8,"_25":8},80,"Mythic Unlock Order","unlock-order-hard",{"_7":106,"_9":107,"_11":108,"_21":-5,"_22":8,"_23":8,"_25":26},83,"Lance-Kitty Strategy","lance-kitty",13,{"_7":109,"_9":111,"_37":81,"_22":8,"_51":112},"Hell Mode",[113,117,121,125],{"_7":114,"_9":115,"_11":116,"_21":-5,"_22":8,"_23":109,"_25":50},66,"Hell Mode Guide","hell-mode",{"_7":118,"_9":119,"_11":120,"_21":-5,"_22":8,"_23":109,"_25":8},65,"Hell Mode Fundamentals","hell-mode-basics",{"_7":122,"_9":123,"_11":124,"_21":-5,"_22":8,"_23":109,"_25":26},67,"Hell Mode Bosses