[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_43":-7,"_44":20,"_45":46,"_174":175},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_27":28,"_41":42},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":26},75,"Indy Treasures","indy-treasures","navbarTitle","gameId","sectionId",16,"sort",3,"blocks",[29],{"_7":30,"_31":18,"_32":33,"_37":38,"_34":-5,"_39":40},306,"pageId","content",{"_34":35,"_32":36},"type","richText","<div class=\"text-width\">\n<h1 class=\"section-header\">Indy</h1>\n<p>Indy is a Support Mythic that can be summoned with a Sheriff, Wolf Warrior, and a Sandman.</p>\n<p>His ult Fortune &amp; Glory allows him to look for a treasure hidden somewhere on the map. These treasures vary in purpose, rarity, and strength. Almost all of them, however, provide a beneficial buff in game.</p>\n<p>From level 6, the treasure location will be briefly revealed once the mana bar fills. You may select Indy to reveal the location again.</p>\n<p>From level 12, the newest treasure found will not be below the currently held tier. For example, if your Indy holds a legendary treasure, it cannot then find a rare treasure since legendary is better than rare. You may, however, find the same treasure but at a lower value within the legendary range.</p>\n<p>For more information on the rarities, ranges, and what each treasure does, see below:</p>\n</div>\n<div class=\"table-container\">\n<table class=\"indy-table\">\n<thead>\n<tr>\n<th>Treasure</th>\n<th>Rarity/Effects</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Useless Skull<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Useless_Skull.png\"></td>\n</tr>\n<tr>\n<td>No effect</td>\n</tr>\n<tr>\n<td>No effect</td>\n</tr>\n<tr>\n<td>No effect</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Old Shield<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Old_Shield.png\"></td>\n</tr>\n<tr>\n<td class=\"indy-rare\">1-20: DEF Reduction</td>\n</tr>\n<tr>\n<td class=\"indy-epic\">22-40: DEF Reduction</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">43-85: DEF Reduction</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Strong Sword<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Strong_Sword.png\"></td>\n</tr>\n<tr>\n<td class=\"indy-rare\">1%-15%: ATK Damage</td>\n</tr>\n<tr>\n<td class=\"indy-epic\">16%-25%: ATK Damage</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">26%-40%: ATK Damage</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Quick Sword<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Quick_Sword.png\"></td>\n</tr>\n<tr>\n<td class=\"indy-rare\">1%-15%: ATK Speed</td>\n</tr>\n<tr>\n<td class=\"indy-epic\">16%-25%: ATK Speed</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">26%-40%: ATK Speed</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Energy Drink<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Energy_Drink.png\"></td>\n</tr>\n<tr>\n<td class=\"indy-rare\">1%&ndash;20%: MP Regen</td>\n</tr>\n<tr>\n<td class=\"indy-epic\">22%&ndash;40%: MP Regen</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">43% &ndash; 85%: MP Regen</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Lucky Gem<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Lucky_Gem.png\"></td>\n</tr>\n<tr>\n<td>-</td>\n</tr>\n<tr>\n<td class=\"indy-epic\">+2: Luck Stone per wave</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">+3: Luck Stone per wave</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Coin Pocket<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Coin_Pocket.png\"></td>\n</tr>\n<tr>\n<td>-</td>\n</tr>\n<tr>\n<td>-</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">+100 &ndash; +240: Coins per wave</td>\n</tr>\n<tr>\n<td class=\"img-cell\" rowspan=\"4\">Cheap Toy<br><img src=\"https://luckydefenseguides.com/pics/indy-treasures/Cheap_Toy.png\"></td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">10/15/20/25/30%: ATK Damage</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">10/15/20/25/30%: ATK Speed</td>\n</tr>\n<tr>\n<td class=\"indy-legendary\">10/15/20/25/30%: ATK MP Regen</td>\n</tr>\n</tbody>\n</table>\n</div>\n<p>&nbsp;</p>","order",32,"files",[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",47,48,56,57,72,87,8,94,109,110,129,130,136,137,24,153],11,{"_7":47,"_9":49,"_37":50,"_22":8,"_51":52},"Main",0,"pages",[53],{"_7":54,"_9":55,"_11":12,"_21":-5,"_22":8,"_23":47,"_25":-5},56,"LD Homepage",12,{"_7":56,"_9":58,"_37":8,"_22":8,"_51":59},"Fundamentals",[60,64,68,73,77,82],{"_7":61,"_9":62,"_11":63,"_21":-5,"_22":8,"_23":56,"_25":50},59,"What's sb/mg?","sb-mg",{"_7":65,"_9":66,"_11":67,"_21":-5,"_22":8,"_23":56,"_25":8},60,"Mythic Categories","mythic-categories",{"_7":69,"_9":70,"_11":71,"_21":-5,"_22":8,"_23":56,"_25":72},57,"How to use stuns","stun-guide",2,{"_7":74,"_9":75,"_11":76,"_21":-5,"_22":8,"_23":56,"_25":26},58,"Defense Reduction Guide","defense-reduction",{"_7":78,"_9":79,"_11":80,"_21":-5,"_22":8,"_23":56,"_25":81},61,"MP Regen Guide","mp-regen",4,{"_7":83,"_9":84,"_11":85,"_21":-5,"_22":8,"_23":56,"_25":86},62,"Attack Speed Increase","attack-speed",5,{"_7":72,"_9":88,"_37":72,"_22":8,"_51":89},"General",[90],{"_7":91,"_9":92,"_11":93,"_21":-5,"_22":8,"_23":72,"_25":-5},81,"Guardian Upgrade Costs","guardian-upgrade-costs",{"_7":8,"_9":95,"_37":26,"_22":8,"_51":96},"Hard Mode",[97,101,105],{"_7":98,"_9":99,"_11":100,"_21":-5,"_22":8,"_23":8,"_25":50},112,"Hard Gameplay Guide","hard-gameplay",{"_7":102,"_9":103,"_11":104,"_21":-5,"_22":8,"_23":8,"_25":8},80,"Mythic Unlock Order","unlock-order-hard",{"_7":106,"_9":107,"_11":108,"_21":-5,"_22":8,"_23":8,"_25":72},83,"Lance-Kitty Strategy","lance-kitty",13,{"_7":109,"_9":111,"_37":81,"_22":8,"_51":112},"Hell Mode",[113,117,121,125],{"_7":114,"_9":115,"_11":116,"_21":-5,"_22":8,"_23":109,"_25":50},66,"Hell Mode Guide","hell-mode",{"_7":118,"_9":119