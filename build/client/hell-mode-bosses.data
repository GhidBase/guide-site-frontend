22":8,"_23":132,"_25":50},71,"How to Upgrade/Unlock Treasures","unlock-treasures",{"_7":146,"_9":147,"_11":148,"_21":-5,"_22":8,"_23":132,"_25":8},69,"Exclusive Treasures","exclusive-treasures",16,{"_7":149,"_9":151,"_37":152,"_22":8,"_51":153},"Other",7,[154,158,162,166,170],{"_7":155,"_9":156,"_11":157,"_21":-5,"_22":8,"_23":149,"_25":50},63,"Help I'm New! Guide Quests","newbie-quests",{"_7":159,"_9":160,"_11":161,"_21":-5,"_22":8,"_23":149,"_25":8},72,"Safe Box Earnings","safe-box-table",{"_7":163,"_9":164,"_11":165,"_21":-5,"_22":8,"_23":149,"_25":26},73,"List of Pets","pets",{"_7":167,"_9":168,"_11":169,"_21":-5,"_22":8,"_23":149,"_25":76},75,"Indy Treasures","indy-treasures",{"_7":171,"_9":172,"_11":173,"_21":-5,"_22":8,"_23":149,"_25":81},74,"Daily Fortunes List","daily-fortunes","origin","http://localhost"]
