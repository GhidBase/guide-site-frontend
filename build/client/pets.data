[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_43":-7,"_44":20,"_45":46,"_174":175},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_27":28,"_41":42},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":26},73,"List of Pets","pets","navbarTitle","gameId","sectionId",16,"sort",2,"blocks",[29],{"_7":30,"_31":18,"_32":33,"_37":38,"_34":-5,"_39":40},304,"pageId","content",{"_34":35,"_32":36},"type","richText","<div class=\"text-width\">\n<h2>List of Pets</h2>\n<p>These are all the different pets you can unlock in the game</p>\n</div>\n<table>\n<thead>\n<tr>\n<th>Rarity</th>\n<th>Pet</th>\n<th>Level 1 Effects</th>\n<th>Level 50 Effects</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td rowspan=\"2\">Immortal</td>\n<td class=\"img-cell\">Poseidon<br><img src=\"https://luckydefenseguides.com/pics/pets/Poseidon.png\" alt=\"\"></td>\n<td>\n<ul>\n<li>When 5 monsters remain until the max monster cap, executes normal monsters with 15% chance each (once per match)</li>\n<li>Increases DMG by 10% upon attacking Boss Units</li>\n</ul>\n</td>\n<td>\n<ul>\n<li>When 5 monsters remain until the max monster cap, executes normal monsters with 30% chance each (once per match)</li>\n<li>Increases DMG by 20% upon attacking Boss Units</li>\n</ul>\n</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Party Cat<br><img src=\"https://luckydefenseguides.com/pics/pets/PartyCat.png\" alt=\"\"></td>\n<td>\n<ul>\n<li>Every 60s, increases the Final DMG of own guardians by 15% for 20s</li>\n<li>Increases CRIT DMG by 10%</li>\n</ul>\n</td>\n<td>\n<ul>\n<li>Every 60s, increases the Final DMG of own guardians by 30% for 20s</li>\n<li>Increases CRIT DMG by 20%</li>\n</ul>\n</td>\n</tr>\n<tr>\n<td rowspan=\"4\">Mythic</td>\n<td class=\"img-cell\">WhaleKing<br><img src=\"https://luckydefenseguides.com/pics/pets/WhaleKing.png\" alt=\"\"></td>\n<td>Increases ATK SPD by 2.5%</td>\n<td>Increases ATK SPD by 10%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Wooroo<br><img src=\"https://luckydefenseguides.com/pics/pets/Wooroo.png\" alt=\"\"></td>\n<td>At the start of each wave, has a 5% chance to obtain 1 Luck Stone</td>\n<td>At the start of each wave, has a 20% chance to obtain 1 Luck Stone</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Drago<br><img src=\"https://luckydefenseguides.com/pics/pets/Drago.png\" alt=\"\"></td>\n<td>Increases CRIT Rate by 2.5%</td>\n<td>Increases CRIT Rate by 10%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Ghostboogie<br><img src=\"https://luckydefenseguides.com/pics/pets/Ghostboogle.png\" alt=\"\"></td>\n<td>Has a 5% chance to obtain 5 bonus Coins on sell</td>\n<td>Has a 30% chance to obtain 20 bonus Coins on sell</td>\n</tr>\n<tr>\n<td rowspan=\"5\">Legendary</td>\n<td class=\"img-cell\">Blander<br><img src=\"https://luckydefenseguides.com/pics/pets/Blander.png\" alt=\"\"></td>\n<td>Increases MAGIC DMG by 5%</td>\n<td>Increases MAGIC DMG by 20%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Rockfish<br><img src=\"https://luckydefenseguides.com/pics/pets/Rockfish.png\" alt=\"\"></td>\n<td>Gain 20 coins at the start of the game</td>\n<td>Gain 70 coins at the start of the game</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Salamander<br><img src=\"https://luckydefenseguides.com/pics/pets/Salamander.png\" alt=\"\"></td>\n<td>1x Free Summon</td>\n<td>3x Free Summon</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Braveheart<br><img src=\"https://luckydefenseguides.com/pics/pets/Braveheart.png\" alt=\"\"></td>\n<td>Increases Physical DMG by 5%</td>\n<td>Increases Physical DMG by 20%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">ShrimpKun<br><img src=\"https://luckydefenseguides.com/pics/pets/ShrimpKun.png\" alt=\"\"></td>\n<td>Increases CRIT DMG by 5%</td>\n<td>Increases CRIT DMG by 20%</td>\n</tr>\n<tr>\n<td rowspan=\"5\">Epic</td>\n<td class=\"img-cell\">Sticky<br><img src=\"https://luckydefenseguides.com/pics/pets/Sticky.png\" alt=\"\"></td>\n<td>Increases ULT DMG by 5%</td>\n<td>Increases ULT DMG by 15%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Helmster<br><img src=\"https://luckydefenseguides.com/pics/pets/Helmster.png\" alt=\"\"></td>\n<td>Reduces enemy DEF by 5</td>\n<td>Reduces enemy DEF by 15</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Grassfish<br><img src=\"https://luckydefenseguides.com/pics/pets/Grassfish.png\" alt=\"\"></td>\n<td>At the start of the game, has a 10% chance to summon a random Common unit</td>\n<td>At the start of the game, has a 25% chance to summon a random Rare unit</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Anthony<br><img src=\"https://luckydefenseguides.com/pics/pets/Anthony.png\" alt=\"\"></td>\n<td>Reduces CD by 2.5%</td>\n<td>Reduces CD by 10%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Ballfish<br><img src=\"https://luckydefenseguides.com/pics/pets/Ballfish.png\" alt=\"\"></td>\n<td>Deals DMG equal to 2% of current HP to nearby enemies every 30s</td>\n<td>Deals DMG equal to 7% of current HP to nearby enemies every 30s</td>\n</tr>\n<tr>\n<td rowspan=\"6\">Rare</td>\n<td class=\"img-cell\">Tube<br><img src=\"https://luckydefenseguides.com/pics/pets/Tube.png\" alt=\"\"></td>\n<td>Increases Basic Attack DMG by 2.5%</td>\n<td>Increases Basic Attack DMG by 10%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Dandan<br><img src=\"https://luckydefenseguides.com/pics/pets/Dandan.png\" alt=\"\"></td>\n<td>Reduces enemy DEF by 2.5</td>\n<td>Reduces enemy DEF by 10</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Coolie<br><img src=\"https://luckydefenseguides.com/pics/pets/Coolie.png\" alt=\"\"></td>\n<td>Reduces enemy MOV SPD by 5%</td>\n<td>Reduces enemy MOV SPD by 20%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Leafish<br><img src=\"https://luckydefenseguides.com/pics/pets/Leafish.png\" alt=\"\"></td>\n<td>Stun nearby enemies for 2.5s every 30 seconds</td>\n<td>Stun nearby enemies for 10s every 30 seconds</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Jelly<br><img src=\"https://luckydefenseguides.com/pics/pets/Jelly.png\" alt=\"\"></td>\n<td>Increases MP Regen by 2.5%</td>\n<td>Increases MP Regen by 10%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Handsome<br><img src=\"https://luckydefenseguides.com/pics/pets/Handsome.png\" alt=\"\"></td>\n<td>Increases DMG by 2.5% upon attacking Boss Units</td>\n<td>Increases DMG by 10% upon attacking BOss Units</td>\n</tr>\n<tr>\n<td rowspan=\"6\">Common</td>\n<td class=\"img-cell\">MonoCell<br><img src=\"https://luckydefenseguides.com/pics/pets/MonoCell.png\" alt=\"\"></td>\n<td>Increases MP Regen by 2%</td>\n<td>Increases MP REgen by 7%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Chili<br><img src=\"https://luckydefenseguides.com/pics/pets/Chili.png\" alt=\"\"></td>\n<td>Increases Basic Attack DMG by 2%</td>\n<td>Increases Basic Attack DMG by 7%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Sproutfish<br><img src=\"https://luckydefenseguides.com/pics/pets/Sproutfish.png\" alt=\"\"></td>\n<td>Increases ULT DMG by 2%</td>\n<td>Increases ULT DMG by 7%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Clawsy<br><img src=\"https://luckydefenseguides.com/pics/pets/Clawsy.png\" alt=\"\"></td>\n<td>Increases DMG by 2% upon attacking Boss Units</td>\n<td>Increases DMG by 7% upon attacking Boss Units</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Squibbly<br><img src=\"https://luckydefenseguides.com/pics/pets/Squibbly.png\" alt=\"\"></td>\n<td>Increases MOV SPD by 3%</td>\n<td>Increases MOV SPD by 13%</td>\n</tr>\n<tr>\n<td class=\"img-cell\">Doughie<br><img src=\"https://luckydefenseguides.com/pics/pets/Doughie.png\" alt=\"\"></td>\n<td>Reduces enemy MOV SPD by 3%</td>\n<td>Reduces enemy MOV SPD by 13%</td>\n</tr>\n</tbody>\n</table>\n<p>&nbsp;</p>","order",32,"files",[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",47,48,56,57,26,87,8,94,109,110,129,130,136,137,24,153],11,{"_7":47,"_9":49,"_37":50,"_22":8,"_51":52},"Main",0,"pages",[53],{"_7":54,"_9":55,"_11":12,"_21":-5,"_22":8,"_23":47,"_25":-5},56,"LD Homepage",12,{"_7":56,"_9":58,"_37":8,"_22":8,"_51":59},"Fundamentals",[60,64,68,72,77,82],{"_