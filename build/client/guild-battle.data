[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_54":-7,"_55":20,"_56":57,"_186":187},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_26":27,"_52":53},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":-5},82,"Guild Battle","guild-battle","navbarTitle","gameId","sectionId",14,"sort","blocks",[28,40,46],{"_7":29,"_30":18,"_31":32,"_36":37,"_33":-5,"_38":39},328,"pageId","content",{"_33":34,"_31":35},"type","richText","<h1 style=\"text-align: left;\">Overview</h1>\n<p style=\"text-align: left;\">Guilds allow you to band together with other players to compete against other guilds in exclusive game modes, work together in the mines to acquire precious resources, and earn plenty of weekly rewards. The Guild Raid game mode is your guilds chance to work together to become a top team in Lucky Defense.&nbsp;<br><br></p>\n<h2 style=\"text-align: left;\">Guild Raid Explained</h2>\n<p style=\"text-align: left;\">The Guild Raid game mode is a 20 wave single player match. Waves of enemies will start moving in, much like a standard game. However, the objective of the game mode is to inflict as much damage as possible on the guild raid boss located at the top of the screen. &nbsp;Enemy waves will stop after wave 10 and wave 20 and will allow your guardians to attack the raid boss. At the conclusion of the game, your total damage inflicted on the boss is added up and that becomes your score. Each guild member is allotted 5 raid attempts per 6 day season, with the sum of all your attempts giving you your final guild raid score. Your guilds total score is added up among all members and ranked globally among all guilds. At the conclusion of the 6 day season you and your guild are rewarded based on your guilds performance.&nbsp;</p>","order",21,"files",[],{"_7":41,"_30":18,"_31":42,"_36":44,"_33":-5,"_38":45},330,{"_33":34,"_31":43},"<h2>General Strategy Guide</h2>\n<p style=\"text-align: left;\"><strong>&bull; </strong>Begin the game by maxing out your summon level. Coin summon until you reach your max guardian cap.&nbsp;</p>\n<p style=\"text-align: left;\">&bull;Prioritize creating the mythics and immortals you need early. Many mythics benefit from acquiring them early and giving them time to attack. Examples: Watt, Mama/GrandMama, Bomba, Ato, Hailey, Vayne</p>\n<p style=\"text-align: left;\">&bull;Continue summoning and acquiring the guardian recipes you need for your strongest mythics. A common strategy is to spend the first 6-7 waves using luck stones to roulette summon and let your coins build, followed by switching to coin summoning.&nbsp;<br><br></p>\n<p style=\"text-align: left;\">&bull;Guild Raid awards 5 luck stones and thousands of coins per wave on top of your safebox gains(up to 6000 coins per wave starting from wave 6). This allows you to spend much more freely. While it is still possible to over spend, you are able to coin summon more aggressively than in other game modes.&nbsp;<br><br></p>\n<p style=\"text-align: left;\">&bull;There are approximate coin thresholds you should be able to reach at waves 10 and 20.</p>\n<p style=\"text-align: left;\">-safebox 4: wave 10 50,000+ wave 20 180,000+<br>-safebox 5: wave 10 55,000+ wave 20 190,000+<br>-safebox 6: wave 10 60,000+ wave 20 200,000+<br>-safebox 7: wave 10 65,000+ wave 20 210,000+<br>-safebox 8: wave 10 70,000+ wave 20 225,000+<br>-safebox 9: wave 10 80,000+ wave 20 245,000+</p>\n<p style=\"text-align: left;\">(These are approximations and can vary based on approach and strategy)</p>\n<p style=\"text-align: left;\">&bull;Wave 10 begins the first boss damage phase. Your guardians are given 2 minutes and 30 seconds to begin inflicting damage on the guild boss. You are inflicting damage at this point, and it's a good idea to have already invested luck stones into your mythic level, but don't sweat attempting to get everything you need by this point. Typically your overall score will come largely from the second and final damage phase at wave 20.</p>\n<p style=\"text-align: left;\">&bull;After the first boss damage phase at wave 10, the enemy waves will continue. Use this time to round out your team of mythics and immortals</p>\n<p style=\"text-align: left;\">&bull;Your final priority before the final boss damage phase should be stacking attack speed buffs and defense reduction buffs if you are using physical damage guardians. Along with stacking buffs, it's vital to reach a high mythic level. Before wave 20, ideally you have reached at least level 17 mythic level.&nbsp;<br><br></p>\n<h2 style=\"text-align: left;\">Gameplay</h2>\n<p style=\"text-align: left;\">Below are videos implementing this strategy. In the video the player has level 8 artifacts and a combat power of roughly 100,000, and used a team of magic damage guardians.</p>\n<p style=\"text-align: left;\">Guardians used in the video:</p>\n<ul>\n<li style=\"text-align: left;\">level 9 Awakened Hailey</li>\n<li style=\"text-align: left;\">level 12 Reaper Dian</li>\n<li style=\"text-align: left;\">level 6 I Am Meow</li>\n<li style=\"text-align: left;\">level 6 GrandMama</li>\n<li style=\"text-align: left;\">level 6 Super Graviton</li>\n<li style=\"text-align: left;\">level 15 Watt</li>\n<li style=\"text-align: left;\">12 Lazy Taoist.&nbsp;</li>\n</ul>",26,[],{"_7":47,"_30":18,"_31":48,"_36":50,"_33":-5,"_38":51},329,{"_33":34,"_31":49},"<h2><span style=\"text-decoration: underline;\">25 Million Run</span></h2>\n<p><iframe title=\"YouTube video player\" src=\"https://www.youtube.com/embed/OuOgq0OfIpI?si=iEEs-UfJX4tMkd1q\" width=\"560\" height=\"315\" frameborder=\"0\" allow=\"accelerometer;\n                            autoplay;\n                            clipboard-write;\n                            encrypted-media;\n                            gyroscope;\n                            picture-in-picture;\n                            web-share;\" allowfullscreen=\"allowfullscreen\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe></p>\n<p>&nbsp;</p>\n<h2><span style=\"text-decoration: underline;\">Gameplay with narration:</span></h2>\n<p><iframe title=\"YouTube video player\" src=\"https://www.youtube.com/embed/yyZnSjRXj9Q?si=_d0CgEtNOlO27cjH\" width=\"560\" height=\"315\" frameborder=\"0\" allow=\"accelerometer;\n                            autoplay;\n                            clipboard-write;\n                            encrypted-media;\n                            gyroscope;\n                            picture-in-picture;\n                            web-share;\" allowfullscreen=\"allowfullscreen\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe></p>",27,[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",58,59,67,68,83,99,8,106,121,122,24,141,144,145,161,162],11,{"_7":58,"_9":60,"_36":61,"_22":8,"_62":63},"Main",0,"pages",[64],{"_7":65,"_9":66,"_11":12,"_21":-5,"_22":8,"_23":58,"_25":-5},56,"LD Homepage",12,{"_7":67,"_9":69,"_36":8,"_22":8,"_62":70},"Fundamentals",[71,75,79,84,89,94],{"_7":72,"_9":73,"_11":74,"_21":-5,"_22":8,"_23":67,"_25":61},59,"What's sb/mg?","sb-mg",{"_7":76,"_9":77,"_11":78,"_21":-5,"_22":8,"_23":67,"_25":8},60,"Mythic Categories","mythic-categories",{"_7":80,"_9":81,"_11":82,"_21":-5,"_22":8,"_23":67,"_25":83},57,"How to use stuns","stun-guide",2,{"_7":85,"_9":86,"_11":87,"_21":-5,"_22":8,"_23":67,"_25":88},58,"Defense Reduction Guide","defense-reduction",3,{"_7":90,"_9":91,"_11":92,"_21":-5,"_22":8,"_23":67,"_25":93},61,"MP Regen Guide","mp-regen",4,{"_7":95,"_9":96,"_11":97,"_21":-5,"_22":8,"_23":67,"_25":98},62,"Attack Speed Increase","attack-speed",5,{"_7":83,"_9":100,"_36":83,"_22":8,"_62":101},"General",[102],{"_7":103,"_9":104,"_11":105,"_21":-5,"_22":8,"_23":83,"_25":-5},81,"Guardian Upgrade Costs","guardian-upgrade-costs",{"_7":8,"_9":107,"_36":88,"_22":8,"_62":108},"Hard Mode",[109,113,117],{"_7":110,"_9":111,"_11":112,"_21":-5,"_22":8,"_23":8,"_25":61},112,"Hard Gameplay Guide","hard-gameplay",{"_7":114,"_9":115,"_11":116,"_21":-5,"_22":8,"_23":8,"_25":8},80,"Mythic Unlock Order","unlock-order-hard",{"_7":118,"_9":119,"_11":120,"_21":-5,"_22":8,"_23":8,"_25":83},83,"Lance-Kitty Strategy","lance-kitty",13,{"_7":121,"_9":123,"_36":93,"_22":8,"_62":124},"Hell Mode",[125,129,133,137],{"_7":126,"_9":127,"_11":128,"_21":-5,"_22":8,"_23":121,"_25":61},66,"Hell Mode Guide","hell-mode",{"_7":130,"_9":131,"_11":132,"_21":-5,"_22":8,"_23":121,"_25":8},65,"Hell Mode Fundamentals","hell-mode-basics",{"_7":134,"_9":135,"_11":136,"_21":-5,"_22":8,"_23":121,"_25":83},67,"Hell Mode Bosses/Debuffs","hell-mode-bosses",{"_7":138,"_9":139,"_11":140,"_21":-5,"_22":8,"_23":121,"_25":88},68,"Magic Hell Build","magic-hell-build",{"_7":24,"_9":19,"_36":98,"_22":8,"_62":142},[143],{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":-5},15,{"_7":144,"_9":146,"_36":147,"_22":8,"_62":148},"Treasures",6,[149,153,157],{"_7":150,"_9":151,"_11":152,"_21":-5,"_22":8,"_23":144,"_25":83},70,"Treasure Upgrade Costs","treasure-upgrade-costs",{"_7":154,"_9":155,"_11":156,"_21":-5,"_22":8,"_23":144,"_25":61},71,"How to Upgrade/Unlock Treasures","unlock-treasures",{"_7":158,"_9":159,"_11":160,"_21":-5,"_22":8,"_23":144,"_25":8},69,"Exclusive Treasures","exclusive-treasures",16,{"_7":161,"_9":163,"_36":164,"_22":8,"_62":165},"Other",7,[166,170,174,178,182],{"_7":167,"_9":168,"_11":169,"_21":-5,"_22":8,"_23":161,"_25":61},63,"Help I'm New! Guide Quests","newbie-quests",{"_7":171,"_9":172,"_11":173,"_21":-5,"_22":8,"_23":161,"_25":8},72,"Safe Box Earnings","safe-box-table",{"_7":175,"_9":176,"_11":177,"_21":-5,"_22":8,"_23":161,"_25":83},73,"List of Pets","pets",{"_7":179,"_9":180,"_11":181,"_21":-5,"_22":8,"_23":161,"_25":88},75,"Indy Treasures","indy-treasures",{"_7":183,"_9":184,"_11":185,"_21":-5,"_22":8,"_23":161,"_25":93},74,"Daily Fortunes List","daily-fortunes","origin","http://localhost"]
