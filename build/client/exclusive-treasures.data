[{"_1":2},"main",{"_3":4},"data",{"_5":6,"_14":15,"_42":-7,"_43":20,"_44":45,"_174":175},"gameData",{"_7":8,"_9":10,"_11":12,"_13":-5},"id",1,"title","Lucky Defense","slug","lucky-defense","navbar","pageData",{"_16":17,"_26":27,"_40":41},"page",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":8},69,"Exclusive Treasures","exclusive-treasures","navbarTitle","gameId","sectionId",15,"sort","blocks",[28],{"_7":29,"_30":18,"_31":32,"_36":37,"_33":-5,"_38":39},300,"pageId","content",{"_33":34,"_31":35},"type","richText","<div class=\"text-width\">\n<h2>List of Exclusive Treasures</h2>\n<p>These are all the unique treasures that only their specific mythic can unlock:</p>\n</div>\n<table>\n<thead>\n<tr>\n<th>Treasure</th>\n<th>Level</th>\n<th>Description</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td rowspan=\"2\">Ninja</td>\n<td>Level 1</td>\n<td>Reactivation Chance +1% for Assassinate. Ult DMG 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Reactivation Chance +15% for Assassinate. Ult DMG +25%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Iron Meow</td>\n<td>Level 1</td>\n<td>Increases Iron Meow v2's skill DMG by 5%. Increases CRIT rate by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases Iron Meow v2's skill DMG by 50%. Increases CRIT rate by 10%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Vayne</td>\n<td>Level 1</td>\n<td>Tumble's cooldown reduction effect increases by 10%. Increases DMG by 1% for 3 seconds after moving.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Tumble's cooldown reduction effect increases by 150%. Increases DMG by 25% for 3 seconds after moving.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Watt</td>\n<td>Level 1</td>\n<td>5% energy returned after all energy is used. Increases ATK SPD by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>50% energy returned after all energy is used. Increases ATK SPD by 10%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Dragon</td>\n<td>Level 1</td>\n<td>Drain Egg Hatch Chance +0.1%, Flame DMG +10% &amp; Increases Skill DMG by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Drain Egg Hatch Chance +3%, Flame DMG +100% &amp; Increases Skill DMG by 20%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Lazy Taoist</td>\n<td>Level 1</td>\n<td>Increases Razorwind duration by 0.1 secs. Increases ATK SPD by 1%.</td>\n</tr>\n<tr>\n<td>Max Level</td>\n<td>Increases Razorwind duration by 0.5 secs. Increases ATK SPD by 10%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Frog</td>\n<td>Level 1</td>\n<td>5% chance to refund 1 random material on each failed curse lift. Increases ULT Damage by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>70% chance to refund 1 random material on each failed curse lift. Increases ULT Damage by 25%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Tar</td>\n<td>Level 1</td>\n<td>1% chance to summon a tier 3 Tar when summoning Tar that is not tier 3. Increases skill Activation Chance by 0.1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>30% chance to summon a tier 3 Tar when summoning Tar that is not tier 3. Increases skill Activation Chance by 4%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Mama</td>\n<td>Level 1</td>\n<td>1% chance to summon an imp upon kill with Fear Skill. Increases skill DMG by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>30% chance to summon an imp upon kill with Fear Skill. Increases skill DMG by 20%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Bomba</td>\n<td>Level 1</td>\n<td>Increases Workout chance by 0.5%. Increases Physical DMG by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases Workout chance by 2.0%. Increases Physical DMG by 20%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Hailey</td>\n<td>Level 1</td>\n<td>Star Power chance increases by 1%. Increases CRIT DMG by 10%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Star Power chance increases by 15%. Increases CRIT DMG by 30%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Kitty Mage</td>\n<td>Level 1</td>\n<td>Increases magic DMG by 1% for 3 seconds after mana recovery. Increases skill Activation Chance by 0.1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases magic DMG by 15% for 3 seconds after mana recovery. Increases skill Activation Chance by 5%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Batman</td>\n<td>Level 1</td>\n<td>Increases DMG by 1% for 10 seconds upon successful upgrade. Increases CRIT rate by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases DMG by 30% for 10 seconds upon successful upgrade. Increases CRIT rate by 10%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Monopoly Man</td>\n<td>Level 1</td>\n<td>Gains 0.1% of the used MP after an ULT. Recovers 1% of MP at the start of a wave.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Gains 5% of the used MP after an ULT. Recovers 20% of MP at the start of a wave.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Blob</td>\n<td>Level 1</td>\n<td>Increases Devour Count by 5 upon Boss Kill. Increases ATK by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases Devour Count by 50 upon Boss Kill. Increases ATK by 20%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Indy</td>\n<td>Level 1</td>\n<td>1% chance to upgrade to a higher-tier treasure upon excavation. Increases MOV SPD by 5%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>30% chance to upgrade to a higher-tier treasure upon excavation. Increases MOV SPD by 80%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Lancelot</td>\n<td>Level 1</td>\n<td>Summon Lancelot with 1 Flame level. Increases MP regen by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Summon Lancelot with 10 Flame level. Increases MP regen by 30%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Pulse Generator</td>\n<td>Level 1</td>\n<td>Energy charge increased by 10%. Increases skill DMG by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Energy charge increased by 100%. Increases skill DMG by 20%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Ato</td>\n<td>Level 1</td>\n<td>Ult Skill Cooldown Reduction Effect increases by 1%. Increases skill Activation Chance by 0.1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Ult Skill Cooldown Reduction Effect increases by 10%. Increases skill Activation Chance by 5%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Orc Shaman</td>\n<td>Level 1</td>\n<td>Increases physical DMG taken by curse-stunned enemies by 1% for 3 seconds. Increases skill Activation Chance by 0.1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases physical DMG taken by curse-stunned enemies by 18% for 8 seconds. Increases skill Activation Chance by 5%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Coldy</td>\n<td>Level 1</td>\n<td>Increases number of Glaciers for Glacier Collision by 3. Increases MP regen by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases number of Glaciers for Glacier Collision by 20. Increases MP regen by 30%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Graviton</td>\n<td>Level 1</td>\n<td>Overheat from power absorption +10%, skill activation chance +0.1%</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Overheat from power absorption +200%, skill activation chance +5%</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Zap</td>\n<td>Level 1</td>\n<td>Increases damage by 10% when attacking the same target with the Arcane Amplification skill. Basic attack damage increases by 1%.</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Increases damage by 100% when attacking the same target with the Arcane Amplification skill. Basic attack damage increases by 25%.</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Rocket Chu</td>\n<td>Level 1</td>\n<td>1% chance to avoid explosion on Overclock failure. Reduces the number of attacks required to use skills by 1%</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>30% chance to avoid explosion on Overclock failure. Reduces the number of attacks required to use skills by 20%</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Master Kun</td>\n<td>Level 1</td>\n<td>Speed of Spiral of Fire increases by 5%. Increases skill Activation Chance by 0.1%</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Speed of Spiral of Fire increases by 50%. Increases skill Activation Chance by 5%</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Verdee</td>\n<td>Level 1</td>\n<td>Ultimate cooldown reduced by 5%, skill activation chance increased by 0.1%</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Ultimate cooldown reduced by 50%, skill activation chance increased by 5%</td>\n</tr>\n<tr>\n<td rowspan=\"2\">Penguin Musician</td>\n<td>Level 1</td>\n<td>Variation skill has a 1% chance to trigger a better performance. Increase skill activation chance by 0.1%</td>\n</tr>\n<tr>\n<td>MAX</td>\n<td>Variation skill has a 20% chance to trigger a better performance. Increase skill activation chance by 5%</td>\n</tr>\n</tbody>\n</table>\n<p>Credit to Yosh and Jubilent for gathering data about the treasure system, who gathered the information and posted it all on the discord before I was able to add it here.</p>","order",32,"files",[],"notFound",false,"gameSlug","pageSlug","sectionsMap",["M",46,47,55,56,71,87,8,94,109,110,129,130,24,136,149,150],11,{"_7":46,"_9":48,"_36":49,"_22":8,"_50":51},"Main",0,"pages",[52],{"_7":53,"_9":54,"_11":12,"_21":-5,"_22":8,"_23":46,"_25":-5},56,"LD Homepage",12,{"_7":55,"_9":57,"_36":8,"_22":8,"_50":58},"Fundamentals",[59,63,67,72,77,82],{"_7":60,"_9":61,"_11":62,"_21":-5,"_22":8,"_23":55,"_25":49},59,"What's sb/mg?","sb-mg",{"_7":64,"_9":65,"_11":66,"_21":-5,"_22":8,"_23":55,"_25":8},60,"Mythic Categories","mythic-categories",{"_7":68,"_9":69,"_11":70,"_21":-5,"_22":8,"_23":55,"_25":71},57,"How to use stuns","stun-guide",2,{"_7":73,"_9":74,"_11":75,"_21":-5,"_22":8,"_23":55,"_25":76},58,"Defense Reduction Guide","defense-reduction",3,{"_7":78,"_9":79,"_11":80,"_21":-5,"_22":8,"_23":55,"_25":81},61,"MP Regen Guide","mp-regen",4,{"_7":83,"_9":84,"_11":85,"_21":-5,"_22":8,"_23":55,"_25":86},62,"Attack Speed Increase","attack-speed",5,{"_7":71,"_9":88,"_36":71,"_22":8,"_50":89},"General",[90],{"_7":91,"_9":92,"_11":93,"_21":-5,"_22":8,"_23":71,"_25":-5},81,"Guardian Upgrade Costs","guardian-upgrade-costs",{"_7":8,"_9":95,"_36":76,"_22":8,"_50":96},"Hard Mode",[97,101,105],{"_7":98,"_9":99,"_11":100,"_21":-5,"_22":8,"_23":8,"_25":49},112,"Hard Gameplay Guide","hard-gameplay",{"_7":102,"_9":103,"_11":104,"_21":-5,"_22":8,"_23":8,"_25":8},80,"Mythic Unlock Order","unlock-order-hard",{"_7":106,"_9":107,"_11":108,"_21":-5,"_22":8,"_23":8,"_25":71},83,"Lance-Kitty Strategy","lance-kitty",13,{"_7":109,"_9":111,"_36":81,"_22":8,"_50":112},"Hell Mode",[113,117,121,125],{"_7":114,"_9":115,"_11":116,"_21":-5,"_22":8,"_23":109,"_25":49},66,"Hell Mode Guide","hell-mode",{"_7":118,"_9":119,"_11":120,"_21":-5,"_22":8,"_23":109,"_25":8},65,"Hell Mode Fundamentals","hell-mode-basics",{"_7":122,"_9":123,"_11":124,"_21":-5,"_22":8,"_23":109,"_25":71},67,"Hell Mode Bosses/Debuffs","hell-mode-bosses",{"_7":126,"_9":127,"_11":128,"_21":-5,"_22":8,"_23":109,"_25":76},68,"Magic Hell Build","magic-hell-build",14,{"_7":129,"_9":131,"_36":86,"_22":8,"_50":132},"Guild Battle",[133],{"_7":134,"_9":131,"_11":135,"_21":-5,"_22":8,"_23":129,"_25":-5},82,"guild-battle",{"_7":24,"_9":137,"_36":138,"_22":8,"_50":139},"Treasures",6,[140,144,148],{"_7":141,"_9":142,"_11":143,"_21":-5,"_22":8,"_23":24,"_25":71},70,"Treasure Upgrade Costs","treasure-upgrade-costs",{"_7":145,"_9":146,"_11":147,"_21":-5,"_22":8,"_23":24,"_25":49},71,"How to Upgrade/Unlock Treasures","unlock-treasures",{"_7":18,"_9":19,"_11":20,"_21":-5,"_22":8,"_23":24,"_25":8},16,{"_7":149,"_9":151,"_36":152,"_22":8,"_50":153},"Other",7,[154,158,162,166,170],{"_7":155,"_9":156,"_11":157,"_21":-5,"_22":8,"_23":149,"_25":49},63,"Help I'm New! Guide Quests","newbie-quests",{"_7":159,"_9":160,"_11":161,"_21":-5,"_22":8,"_23":149,"_25":8},72,"Safe Box Earnings","safe-box-table",{"_7":163,"_9":164,"_11":165,"_21":-5,"_22":8,"_23":149,"_25":71},73,"List of Pets","pets",{"_7":167,"_9":168,"_11":169,"_21":-5,"_22":8,"_23":149,"_25":76},75,"Indy Treasures","indy-treasures",{"_7":171,"_9":172,"_11":173,"_21":-5,"_22":8,"_23":149,"_25":81},74,"Daily Fortunes List","daily-fortunes","origin","http://localhost"]
